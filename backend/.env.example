APP_NAME=Smart Faculty Face Attendance System
APP_ENV=development
API_PREFIX=/api/v1

ESP32_CAM_URL=http://192.168.1.30/
ESP32_CAM_SNAPSHOT_PATH=/capture
ESP32_CAM_STREAM_URL=http://192.168.1.30:81/stream
CAMERA_TIMEOUT_SECONDS=5
CAMERA_STREAM_READ_BYTES=65536

FACENET_PRETRAINED_MODEL=vggface2
FACE_RECOGNITION_THRESHOLD=0.7
MEDIAPIPE_FACE_MIN_CONFIDENCE=0.6
MEDIAPIPE_FACE_MODEL_PATH=backend/data/models/blaze_face_short_range.tflite

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=480

DATABASE_PATH=data/db/attendance.sqlite3
IMPORTS_DIR=data/imports
EXPORTS_DIR=data/exports
KNOWN_FACES_DIR=data/known_faces
MODELS_DIR=data/models
BENCHMARKS_DIR=data/benchmarks
