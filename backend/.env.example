APP_NAME=Smart Faculty Face Attendance System
APP_ENV=development
API_PREFIX=/api/v1

ESP32_CAM_URL=http://192.168.1.30/
ESP32_CAM_SNAPSHOT_PATH=/capture
ESP32_CAM_STREAM_URL=http://192.168.1.30:81/stream
CAMERA_TIMEOUT_SECONDS=5
CAMERA_STREAM_READ_BYTES=65536

FACENET_PRETRAINED_MODEL=vggface2
FACE_RECOGNITION_THRESHOLD=0.75

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
SECRET_KEY=change-this-secret-key

DATABASE_PATH=backend/data/db/attendance.sqlite3
IMPORTS_DIR=backend/data/imports
EXPORTS_DIR=backend/data/exports
KNOWN_FACES_DIR=backend/data/known_faces
MODELS_DIR=backend/data/models
BENCHMARKS_DIR=backend/data/benchmarks
